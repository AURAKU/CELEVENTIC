# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
.cache/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/*.db
prisma/*.db-journal

# local user uploads (folder structure kept via .gitkeep)
public/uploads/**
!public/uploads/
!public/uploads/**/
!public/uploads/**/.gitkeep

# video backfill runtime state (manifests, audit logs, SQLite backups, rollback files) —
# never committed; regenerated per run, may contain local file paths/DB content.
/var/video-backfill/

# celeventic-video-worker liveness heartbeat (src/lib/video/worker-heartbeat.ts) — runtime state, regenerated every tick.
/var/video-worker/
