# App — use your live domain in production (never localhost on live)
# Examples: https://www.celeventic.com | https://www.celeventic.org | https://www.celeventic.online
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Celeventic

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/celeventic?schema=public"

# Auth — must match your live domain in production
NEXTAUTH_URL=http://localhost:3000
# On live hosts (celeventic.com/org/online), set AUTH_TRUST_HOST=true so callbacks use the request domain
AUTH_TRUST_HOST=true

# Optional: custom upload directory (defaults to public/uploads locally, /tmp on serverless)
# UPLOAD_DIR=
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
# One-time live bootstrap: POST /api/setup/ensure-admin with header x-setup-secret
# Idempotent admin seed: npm run seed:admin
SETUP_SECRET=
# Set true only when intentionally resetting demo admin passwords
FORCE_RESET_ADMIN_PASSWORD=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment Providers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=

# Communication
RESEND_API_KEY=
SMS_PROVIDER_API_KEY=
WHATSAPP_BUSINESS_TOKEN=

# Storage — AWS S3 (+ CloudFront / public base URL recommended for fast media)
# When any of region / access key / secret / bucket is missing, uploads fall back to local disk
# (public/uploads or UPLOAD_DIR) and are served via /api/uploads/... — pages keep working.
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=celeventic-production-media
# Optional key prefix inside the bucket (default: uploads)
AWS_S3_KEY_PREFIX=uploads
# Preferred public media origin (CloudFront or custom CDN), e.g. https://media.celeventic.com
AWS_CLOUDFRONT_URL=https://media.celeventic.com
AWS_CLOUDFRONT_DOMAIN=https://media.celeventic.com
# Aliases for the same CDN/public base (first non-empty wins):
# AWS_S3_PUBLIC_BASE_URL=
# AWS_S3_PUBLIC_URL=
# NEXT_PUBLIC_MEDIA_CDN_URL=
# Optional MinIO/LocalStack endpoint
# AWS_S3_ENDPOINT=
# Only if your bucket uses object ACLs instead of a bucket policy:
# AWS_S3_PUBLIC_READ_ACL=false
# Optional: override local upload root (defaults to public/uploads, or /tmp on serverless)
# UPLOAD_DIR=

# ─── Universal Video Upload & Processing (S3 direct multipart + MediaConvert or VPS FFmpeg) ───
# Set to "s3" to route NEW video uploads through the direct-to-S3 multipart pipeline
# (src/app/api/uploads/video/*). Existing Cloudinary/local/S3 URLs keep working either way.
MEDIA_STORAGE_PROVIDER=s3
VIDEO_PROCESSING_ENABLED=true

# Which engine transcodes queued videos for the S3 pipeline above: "ffmpeg" (VPS-local, what
# production Hostinger uses) or "mediaconvert" (AWS Elemental, multi-rendition + HLS). Leave
# blank to auto-detect: mediaconvert when AWS_MEDIACONVERT_ROLE_ARN is set, otherwise ffmpeg.
VIDEO_PROCESSOR=ffmpeg

# IAM role MediaConvert assumes to read the raw upload and write processed outputs to S3.
# Create in IAM: trust policy for mediaconvert.amazonaws.com, permissions s3:GetObject on
# uploads/raw/videos/* and s3:PutObject on processed/videos/* in AWS_S3_BUCKET.
# Only needed when VIDEO_PROCESSOR=mediaconvert.
AWS_MEDIACONVERT_ROLE_ARN=
# Account-specific MediaConvert endpoint (AWS Console → MediaConvert → Account). Leave blank to
# auto-discover via DescribeEndpoints on first job (slightly slower cold start, cached after).
AWS_MEDIACONVERT_ENDPOINT=
# Optional dedicated MediaConvert queue ARN (defaults to the account's "Default" queue when blank).
AWS_MEDIACONVERT_QUEUE_ARN=

# ─── VPS FFmpeg video processor (src/lib/video/video-processor.ts) ───
# Used by BOTH the invitations upload route (src/app/api/invitations/upload) and, when
# VIDEO_PROCESSOR=ffmpeg above, the universal S3 video pipeline. Converts any uploaded video
# (incl. iPhone HEVC/Dolby Vision) to browser-universal H.264/AAC MP4 with faststart.
# Absolute path to the production converter script (checked first; falls back to raw
# ffmpeg/ffprobe below if missing or it fails). Hostinger production already has this at:
CELEVENTIC_VIDEO_CONVERTER_PATH=/usr/local/bin/celeventic-process-video
# Override only if ffmpeg/ffprobe aren't on PATH (defaults to "ffmpeg" / "ffprobe"):
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
# Hard per-process timeout before an ffmpeg/converter run is killed.
VIDEO_PROCESSOR_TIMEOUT_MS=900000
# Max concurrent transcodes on this box. v1 default is 1 (documented limitation — a single
# VPS has finite CPU; raise only after load-testing your instance size).
VIDEO_PROCESSOR_CONCURRENCY=1

# Global fallback max video size in MB (used only if a category-specific var below is unset).
VIDEO_MAX_SIZE_MB=
# Per-category max sizes in MB — every category also has an admin-editable override
# (Admin → Settings) that takes precedence over these when set.
VIDEO_EVENT_SHORT_MAX_SIZE_MB=250
VIDEO_INVITATION_BG_MAX_SIZE_MB=150
VIDEO_VENDOR_PORTFOLIO_MAX_SIZE_MB=500
VIDEO_GUESTBOOK_MAX_SIZE_MB=300
VIDEO_PREMIUM_MAX_SIZE_MB=2048
VIDEO_ADMIN_MAX_SIZE_MB=5120

# Hours an incomplete (UPLOADING) multipart upload sits idle before the worker auto-aborts it.
VIDEO_ABANDONED_UPLOAD_HOURS=24
# How often (ms) the standalone job worker (npm run jobs:worker) ticks — see scripts/video-jobs-worker.ts.
JOB_WORKER_TICK_MS=15000

# Maps & Analytics
GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Laravel API (optional — connects Next.js to Laravel backend)
LARAVEL_API_URL=http://localhost:8000/api/v1
LARAVEL_API_TOKEN=

# Encryption (API secrets at rest)
ENCRYPTION_KEY=

# Monitoring
SENTRY_DSN=
POSTHOG_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=

# AI
OPENAI_API_KEY=
