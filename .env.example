# App — use your live domain in production (never localhost on live)
# Examples: https://www.celeventic.com | https://www.celeventic.org | https://www.celeventic.online
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Celeventic

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/celeventic?schema=public"

# Auth — must match your live domain in production
NEXTAUTH_URL=http://localhost:3000
# On live hosts (celeventic.com/org/online), set AUTH_TRUST_HOST=true so callbacks use the request domain
AUTH_TRUST_HOST=true

# Optional: custom upload directory (defaults to public/uploads locally, /tmp on serverless)
# UPLOAD_DIR=
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
# One-time live bootstrap: POST /api/setup/ensure-admin with header x-setup-secret
# Idempotent admin seed: npm run seed:admin
SETUP_SECRET=
# Set true only when intentionally resetting demo admin passwords
FORCE_RESET_ADMIN_PASSWORD=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment Providers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=

# Communication
RESEND_API_KEY=
SMS_PROVIDER_API_KEY=
WHATSAPP_BUSINESS_TOKEN=

# Storage — AWS S3 (+ CloudFront / public base URL recommended for fast media)
# When any of region / access key / secret / bucket is missing, uploads fall back to local disk
# (public/uploads or UPLOAD_DIR) and are served via /api/uploads/... — pages keep working.
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=celeventic-production-media
# Optional key prefix inside the bucket (default: uploads)
AWS_S3_KEY_PREFIX=uploads
# Preferred public media origin (CloudFront or custom CDN), e.g. https://media.celeventic.com
AWS_CLOUDFRONT_URL=https://media.celeventic.com
AWS_CLOUDFRONT_DOMAIN=https://media.celeventic.com
# Aliases for the same CDN/public base (first non-empty wins):
# AWS_S3_PUBLIC_BASE_URL=
# AWS_S3_PUBLIC_URL=
# NEXT_PUBLIC_MEDIA_CDN_URL=
# Optional MinIO/LocalStack endpoint
# AWS_S3_ENDPOINT=
# Only if your bucket uses object ACLs instead of a bucket policy:
# AWS_S3_PUBLIC_READ_ACL=false
# Optional: override local upload root (defaults to public/uploads, or /tmp on serverless)
# UPLOAD_DIR=

# ─── Universal Video Upload & Processing (S3 direct multipart + MediaConvert or VPS FFmpeg) ───
# Set to "s3" to route NEW video uploads through the direct-to-S3 multipart pipeline
# (src/app/api/uploads/video/*). Existing Cloudinary/local/S3 URLs keep working either way.
#
# IMPORTANT: this does NOT hard-require S3. If MEDIA_STORAGE_PROVIDER=s3 but AWS_REGION /
# AWS_S3_BUCKET / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY aren't all set (or the AWS_S3
# integration isn't enabled in Admin), the presign API automatically falls back to uploading
# through this server + VPS FFmpeg (src/app/api/uploads/video/local, see
# src/lib/video/storage-strategy.ts) instead of blocking the upload with a "not configured"
# error. This is the normal, permanent, supported mode for Hostinger VPS deployments that
# don't use AWS at all — just leave the AWS_* vars below blank and set VIDEO_PROCESSOR=ffmpeg.
MEDIA_STORAGE_PROVIDER=s3
# Set to "false" to restore the old strict behavior (reject uploads instead of falling back
# to local disk + FFmpeg when S3 isn't configured). Leave unset/"true" on every environment
# unless you specifically want uploads to hard-fail without S3.
VIDEO_LOCAL_FALLBACK_ENABLED=true
VIDEO_PROCESSING_ENABLED=true

# Which engine transcodes queued videos for the S3 pipeline above: "ffmpeg" (VPS-local, what
# production Hostinger uses) or "mediaconvert" (AWS Elemental, multi-rendition + HLS). Leave
# blank to auto-detect: mediaconvert when AWS_MEDIACONVERT_ROLE_ARN is set, otherwise ffmpeg.
VIDEO_PROCESSOR=ffmpeg

# IAM role MediaConvert assumes to read the raw upload and write processed outputs to S3.
# Create in IAM: trust policy for mediaconvert.amazonaws.com, permissions s3:GetObject on
# uploads/raw/videos/* and s3:PutObject on processed/videos/* in AWS_S3_BUCKET.
# Only needed when VIDEO_PROCESSOR=mediaconvert.
AWS_MEDIACONVERT_ROLE_ARN=
# Account-specific MediaConvert endpoint (AWS Console → MediaConvert → Account). Leave blank to
# auto-discover via DescribeEndpoints on first job (slightly slower cold start, cached after).
AWS_MEDIACONVERT_ENDPOINT=
# Optional dedicated MediaConvert queue ARN (defaults to the account's "Default" queue when blank).
AWS_MEDIACONVERT_QUEUE_ARN=

# ─── VPS FFmpeg video processor (src/lib/video/video-processor.ts) ───
# Used by BOTH the invitations upload route (src/app/api/invitations/upload) and, when
# VIDEO_PROCESSOR=ffmpeg above, the universal S3 video pipeline. Converts any uploaded video
# (incl. iPhone HEVC/Dolby Vision) to browser-universal H.264/AAC MP4 with faststart.
#
# DEFAULT: adaptive TypeScript ffprobe+ffmpeg (capability detection + HDR fallback when
# zscale/tonemap are missing). Hostinger should rely on this path.
#
# Optional Hostinger binary — OFF by default. Presence of the binary alone must NOT enable it
# (it may hard-require zscale with no fallback). Only set to true after verifying the binary
# works on this host; any failure still falls through to adaptive ffmpeg.
# VIDEO_USE_EXTERNAL_CONVERTER=true
# Absolute path to the optional production converter script (only used when opted in above):
# CELEVENTIC_VIDEO_CONVERTER_PATH=/usr/local/bin/celeventic-process-video
# Generic alias for the same setting (some ops docs/scripts refer to it by this name) — either
# one works; CELEVENTIC_VIDEO_CONVERTER_PATH wins if both are set.
# VIDEO_PROCESSOR_PATH=/usr/local/bin/celeventic-process-video
# Override only if ffmpeg/ffprobe aren't on PATH (defaults to "ffmpeg" / "ffprobe"):
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
# Hard per-process timeout before an ffmpeg/converter run is killed.
VIDEO_PROCESSOR_TIMEOUT_MS=900000
# Max concurrent transcodes on this box. v1 default is 1 (documented limitation — a single
# VPS has finite CPU; raise only after load-testing your instance size).
VIDEO_PROCESSOR_CONCURRENCY=1

# Global fallback max video size in MB (used only if a category-specific var below is unset).
VIDEO_MAX_SIZE_MB=
# Per-category max sizes in MB — every category also has an admin-editable override
# (Admin → Settings) that takes precedence over these when set.
VIDEO_EVENT_SHORT_MAX_SIZE_MB=250
VIDEO_INVITATION_BG_MAX_SIZE_MB=150
VIDEO_VENDOR_PORTFOLIO_MAX_SIZE_MB=500
VIDEO_GUESTBOOK_MAX_SIZE_MB=300
VIDEO_PREMIUM_MAX_SIZE_MB=2048
VIDEO_ADMIN_MAX_SIZE_MB=5120

# Hours an incomplete (UPLOADING) multipart upload sits idle before the worker auto-aborts it.
VIDEO_ABANDONED_UPLOAD_HOURS=24
# How often (ms) the standalone job worker (npm run jobs:worker) ticks — see scripts/video-jobs-worker.ts.
JOB_WORKER_TICK_MS=15000

# ─── Stale-job / stuck-processing recovery (see src/lib/video/cleanup.ts, src/lib/queue.ts) ───
# Fixes videos left stuck on "processing" forever when the video-jobs-worker process dies
# mid-transcode (pm2 restart, OOM kill, VPS reboot). The worker's every-tick sweep resets a
# stuck VideoAsset back to QUEUED (and re-dispatches its job) up to VIDEO_MAX_PROCESSING_ATTEMPTS
# times, then marks it FAILED with a clear, actionable reason instead of spinning forever.
#
# Minutes a VideoAsset can sit in PROCESSING before it's considered stuck. Default (20) = the
# 15-minute ffmpeg hard timeout (VIDEO_PROCESSOR_TIMEOUT_MS) + a 5-minute buffer — keep this
# comfortably above VIDEO_PROCESSOR_TIMEOUT_MS or you'll requeue videos that are still legitimately
# transcoding.
VIDEO_STALE_PROCESSING_MINUTES=20
# How many total processing attempts a video gets before it's marked FAILED instead of retried again.
VIDEO_MAX_PROCESSING_ATTEMPTS=3
# Minutes a generic BackgroundJob row (any queue) can sit in PROCESSING before the worker
# considers it abandoned by a crashed process and resets it to PENDING (or FAILED past maxAttempts).
JOB_STALE_MINUTES=30

# ─── Worker liveness heartbeat (src/lib/video/worker-heartbeat.ts) ───
# celeventic-video-worker writes a small JSON heartbeat file on every tick (and after every job)
# so the Next.js app can tell "worker isn't running" apart from "worker is alive but busy with a
# previous large video" — a pure queue-depth check can't make that distinction. No DB/schema
# change required; both processes already share the same VPS filesystem.
# How stale the heartbeat can get before the worker is considered NOT running.
VIDEO_WORKER_HEARTBEAT_STALE_MS=90000
# Optional: override where the heartbeat file lives (defaults to var/video-worker/heartbeat.json,
# repo-relative). Only needed for isolated test runs or an unusual deployment layout.
# VIDEO_WORKER_HEARTBEAT_DIR=

# ─── In-process inline-fallback (src/lib/video/inline-fallback.ts) ───
# Self-heals a VideoAsset stuck QUEUED because celeventic-video-worker isn't running — checked on
# every status-poll request (GET /api/uploads/video/:id), so no separate cron/kick endpoint is
# needed. Fires ONLY when the worker heartbeat above is confirmed stale (never for a worker that's
# simply busy) AND the asset has been QUEUED longer than VIDEO_INLINE_FALLBACK_AFTER_MS:
#   - size <= VIDEO_INLINE_FALLBACK_MAX_MB: transcodes right here in the Next.js server process,
#     fire-and-forget (never blocks the poll request/response — safe from the ECONNRESET class of
#     bug because it's never attached to an upload request).
#   - size >  VIDEO_INLINE_FALLBACK_MAX_MB: marks the asset FAILED with an actionable "worker not
#     running" message instead of leaving the UI stuck on a vague timeout forever.
VIDEO_INLINE_FALLBACK_ENABLED=true
VIDEO_INLINE_FALLBACK_AFTER_MS=45000
VIDEO_INLINE_FALLBACK_MAX_MB=200

# Maps & Analytics
GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Laravel API (optional — connects Next.js to Laravel backend)
LARAVEL_API_URL=http://localhost:8000/api/v1
LARAVEL_API_TOKEN=

# Encryption (API secrets at rest)
ENCRYPTION_KEY=

# Monitoring
SENTRY_DSN=
POSTHOG_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=

# AI
OPENAI_API_KEY=
