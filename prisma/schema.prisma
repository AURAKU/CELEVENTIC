model EventTimelineItem {
  id          String  @id @default(cuid())
  eventPlanId String
  title       String
  description String?
  dueDate     String?
  phase       String?
  status      String  @default("pending")
  priority    String  @default("medium")

  plan EventPlan @relation(fields: [eventPlanId], references: [id], onDelete: Cascade)

  @@map("event_timeline_items")
}

model EventChecklistItem {
  id          String  @id @default(cuid())
  eventPlanId String
  task        String
  assignedTo  String?
  dueDate     String?
  status      String  @default("pending")
  priority    String  @default("medium")

