generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  VENDOR
  VENUE_OWNER
  AGENCY
  STAFF
  GUEST
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id             String     @id @default(cuid())
  email          String?    @unique
  phone          String?    @unique
  passwordHash   String?
  name           String
  avatarUrl      String?
  role           UserRole   @default(ORGANIZER)
  status         UserStatus @default(ACTIVE)
  organizationId String?
  emailVerified  DateTime?
  phoneVerified  DateTime?
  isVerified     Boolean    @default(false)
  lastLoginAt            DateTime?
  acceptedTermsVersion   String?
  acceptedPrivacyVersion String?
  cookieConsent          String?
  consentTimestamp       DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  organization     Organization?  @relation(fields: [organizationId], references: [id])
  accounts         Account[]
  sessions         Session[]
  events           Event[]
  guests           Guest[]
  tickets          Ticket[]
  ticketOrders     TicketOrder[]
  payments         Payment[]
  campaigns        Campaign[]
  vendors          Vendor[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  contributions    Contribution[]
  vendorBookings   VendorBooking[]
  venueBookings    VenueBooking[]
  qrScans          QrScan[]
  offlineDevices   OfflineDevice[]
  twoFactor        TwoFactorAuth?
  flyerDesigns       FlyerDesign[]
  inspirationUploads InspirationUpload[]
  eventStaff         EventStaff[]
  vendorReviews         VendorReview[]
  vendorFavorites       VendorFavorite[]
  vendorLeadsSubmitted  VendorLead[]
  vendorClaimRequests   VendorClaimRequest[]
  venueProfiles         Venue[]              @relation("VenueOwner")
  designTemplates    DesignTemplate[]  @relation("TemplateCreator")
  designedTemplates  DesignTemplate[]  @relation("TemplateDesigner")
  designerProfile    DesignerProfile?
  templateFavorites  TemplateFavorite[]
  templatePurchases  TemplatePurchase[]
  designExports      DesignExport[]
  aiDesignRequests   AiDesignRequest[]
  invitationOrders       InvitationOrder[]
  assignedInvitationOrders InvitationOrder[] @relation("OrderDesigner")
  languagePreference     UserLanguagePreference?
  generatedDesigns   GeneratedDesign[]
  eventPlans         EventPlan[]
  memoryVaults       MemoryVault[]
  aiRequests         AiRequest[]
  walletTransactions       WalletTransaction[]    @relation("WalletTransactionCreator")
  consentRecords           UserConsentRecord[]
  revisionComments         RevisionComment[]
  productionAssignments    ProductionAssignment[] @relation("ProductionDesigner")

  @@index([role])
  @@index([status])
  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Events ─────────────────────────────────────────────────────

enum EventType {
  WEDDING
  FUNERAL
  BIRTHDAY
  CONFERENCE
  CHURCH_PROGRAM
  CORPORATE_EVENT
  CONCERT
  FESTIVAL
  SCHOOL_EVENT
  PRODUCT_LAUNCH
  PRIVATE_EVENT
  CUSTOM
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  COMPLETED
  CANCELLED
}

enum PricingType {
  FREE
  PAID
}

model Event {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  eventType       EventType
  hostName        String
  description     String?    
  startDate       DateTime
  endDate         DateTime?
  venueName       String?
  landmark        String?
  mapsLink        String?
  contactPhone    String?
  dressCode       String?
  expectedGuests  Int?
  pricingType     PricingType @default(FREE)
  coverImageUrl   String?
  themeId         String?
  packageId       String?
  organizationId  String?
  city            String?
  region          String?
  country         String?     @default("GH")
  latitude        Decimal?   
  longitude       Decimal?   
  isPublic        Boolean     @default(false)
  isFeatured      Boolean     @default(false)
  status          EventStatus @default(DRAFT)
  organizerId     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organizer      User           @relation(fields: [organizerId], references: [id])
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  package        EventPackage?  @relation(fields: [packageId], references: [id])
  theme          EventTemplate? @relation("EventTheme", fields: [themeId], references: [id])
  invitations    Invitation[]
  guests         Guest[]
  tickets        Ticket[]
  ticketOrders   TicketOrder[]
  qrCodes        QrCode[]
  qrScans        QrScan[]
  campaigns      Campaign[]
  contributions  Contribution[]
  memories       EventMemory[]
  media          EventMedia[]
  offlineDevices OfflineDevice[]
  flyerDesigns   FlyerDesign[]
  inspirationUploads InspirationUpload[]
  gates          EventGate[]
  staff          EventStaff[]
  seatingPlans   SeatingPlan[]
  expenses       EventExpense[]
  wallet         Wallet?
  fraudLogs      FraudDetectionLog[]
  reminders      ReminderSchedule[]
  eventPlans     EventPlan[]
  funeralProfile FuneralProfile?
  tributeMessages TributeMessage[]
  funeralPrograms FuneralProgram[]
  memoryVault    MemoryVault?

  @@index([organizerId])
  @@index([organizationId])
  @@index([status])
  @@index([eventType])
  @@index([isPublic, isFeatured])
  @@index([city, country])
  @@map("events")
}

model EventPackage {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String? 
  price           Decimal 
  currency        String   @default("GHS")
  guestLimit      Int      @default(100)
  invitationLimit Int      @default(50)
  ticketLimit     Int      @default(500)
  smsCredits      Int      @default(0)
  emailCredits    Int      @default(0)
  whatsappCredits Int      @default(0)
  features        Json?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events Event[]

  @@map("event_packages")
}

model EventTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  previewUrl  String?
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  themedEvents Event[] @relation("EventTheme")
  invitations  Invitation[]

  @@map("event_templates")
}

model EventMedia {
  id        String   @id @default(cuid())
  eventId   String
  url       String
  type      String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_media")
}

// ─── Invitations & Guests ───────────────────────────────────────

enum InvitationStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

enum GuestStatus {
  INVITED
  OPENED
  ACCEPTED
  DECLINED
  MAYBE
  CHECKED_IN
  NO_SHOW
}

enum RsvpResponse {
  ACCEPTED
  DECLINED
  MAYBE
}

model Invitation {
  id           String           @id @default(cuid())
  eventId      String
  name         String
  slug         String           @unique
  templateId   String?
  message      String?         
  designConfig Json?
  status       InvitationStatus @default(DRAFT)
  uniqueLink   String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template EventTemplate? @relation(fields: [templateId], references: [id])
  guests   Guest[]
  blocks   InvitationBlock[]

  @@index([eventId])
  @@map("invitations")
}

model GuestGroup {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  createdAt DateTime @default(now())

  guests Guest[]

  @@map("guest_groups")
}

model Guest {
  id            String      @id @default(cuid())
  eventId       String
  invitationId  String?
  groupId       String?
  userId        String?
  name          String
  email         String?
  phone         String?
  status        GuestStatus @default(INVITED)
  qrToken       String      @unique @default(cuid())
  plusOnes      Int         @default(0)
  notes            String?
  inviteOpenedAt   DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitation Invitation? @relation(fields: [invitationId], references: [id])
  group      GuestGroup? @relation(fields: [groupId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  rsvps      Rsvp[]
  qrCodes    QrCode[]
  qrScans    QrScan[]
  tickets    Ticket[]

  @@index([eventId])
  @@index([status])
  @@map("guests")
}

model Rsvp {
  id        String       @id @default(cuid())
  guestId   String
  response  RsvpResponse
  message   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("rsvps")
}

// ─── Ticketing ──────────────────────────────────────────────────

enum TicketType {
  FREE
  PAID
  VIP
  VVIP
  GROUP
  TABLE
}

enum TicketStatus {
  PENDING
  PAID
  USED
  CANCELLED
  REFUNDED
  EXPIRED
}

model Ticket {
  id          String       @id @default(cuid())
  eventId     String
  guestId     String?
  userId      String?
  type        TicketType   @default(FREE)
  name        String
  description String?
  price       Decimal      @default(0)
  currency    String       @default("GHS")
  quantity    Int          @default(1)
  soldCount   Int          @default(0)
  maxQuantity Int?
  status      TicketStatus @default(PENDING)
  promoCode   String?
  qrToken     String       @unique @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest  Guest?  @relation(fields: [guestId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
  orders TicketOrder[]
  qrCodes QrCode[]
  qrScans QrScan[]

  @@index([eventId])
  @@map("tickets")
}

model TicketOrder {
  id          String       @id @default(cuid())
  eventId     String
  ticketId    String
  userId      String?
  buyerName   String
  buyerEmail  String?
  buyerPhone  String?
  quantity    Int          @default(1)
  totalAmount Decimal     
  currency    String       @default("GHS")
  status      TicketStatus @default(PENDING)
  promoCode   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event    Event     @relation(fields: [eventId], references: [id])
  ticket   Ticket    @relation(fields: [ticketId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  payments Payment[]

  @@index([eventId])
  @@map("ticket_orders")
}

// ─── Payments ───────────────────────────────────────────────────

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  HUBTEL
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
  DISPUTED
}

enum PaymentPurpose {
  EVENT_PACKAGE
  TICKET_PURCHASE
  BULK_MESSAGING
  ADVERTISING
  VENDOR_BOOKING
  CONTRIBUTION
  INVITATION_ORDER
  INVITATION_REVISION
}

model Payment {
  id                  String          @id @default(cuid())
  userId              String?
  reference           String          @unique
  provider            PaymentProvider
  purpose             PaymentPurpose
  amount              Decimal
  currency            String          @default("GHS")
  baseCurrency        String          @default("GHS")
  baseAmount          Decimal?
  displayCurrency     String?
  displayAmount       Decimal?
  exchangeRate        Decimal?
  idempotencyKey      String?         @unique
  status              PaymentStatus   @default(PENDING)
  metadata            Json?
  ticketOrderId       String?
  campaignId          String?
  invitationOrderId   String?         @unique
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user              User?                @relation(fields: [userId], references: [id])
  ticketOrder       TicketOrder?         @relation(fields: [ticketOrderId], references: [id])
  campaign          Campaign?            @relation(fields: [campaignId], references: [id])
  invitationOrder   InvitationOrder?     @relation(fields: [invitationOrderId], references: [id])
  logs              PaymentLog[]
  currencyLogs      PaymentCurrencyLog[]
  revisionPayment   RevisionPayment?

  @@index([status])
  @@index([reference])
  @@map("payments")
}

model PaymentLog {
  id        String   @id @default(cuid())
  paymentId String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_logs")
}

// ─── QR System ──────────────────────────────────────────────────

enum QrScanResult {
  VALID
  INVALID
  ALREADY_USED
  EXPIRED
  WRONG_EVENT
}

model QrCode {
  id        String   @id @default(cuid())
  eventId   String
  guestId   String?
  ticketId  String?
  token     String   @unique
  type      String
  expiresAt DateTime?
  createdAt DateTime @default(now())

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest  Guest?  @relation(fields: [guestId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])
  scans  QrScan[]

  @@index([token])
  @@map("qr_codes")
}

model QrScan {
  id         String       @id @default(cuid())
  eventId    String
  qrCodeId   String?
  guestId    String?
  ticketId   String?
  scannedBy  String?
  gate       String?
  result     QrScanResult
  deviceInfo String?
  createdAt  DateTime     @default(now())

  event     Event    @relation(fields: [eventId], references: [id])
  qrCode    QrCode?  @relation(fields: [qrCodeId], references: [id])
  guest     Guest?   @relation(fields: [guestId], references: [id])
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
  scanner   User?    @relation(fields: [scannedBy], references: [id])

  @@index([eventId])
  @@map("qr_scans")
}

// ─── Offline QR ─────────────────────────────────────────────────

model OfflineDevice {
  id           String   @id @default(cuid())
  eventId      String
  userId       String
  deviceName   String
  deviceToken  String   @unique
  isAuthorized Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())

  event    Event             @relation(fields: [eventId], references: [id])
  user     User              @relation(fields: [userId], references: [id])
  checkins OfflineCheckin[]
  syncLogs OfflineSyncLog[]

  @@map("offline_devices")
}

model OfflineCheckin {
  id           String   @id @default(cuid())
  deviceId     String
  guestId      String?
  ticketId     String?
  qrToken      String
  result       QrScanResult
  checkedInAt  DateTime @default(now())
  synced       Boolean  @default(false)
  syncedAt     DateTime?

  device OfflineDevice @relation(fields: [deviceId], references: [id])

  @@map("offline_checkins")
}

model OfflineSyncLog {
  id         String   @id @default(cuid())
  deviceId   String
  action     String
  records    Int      @default(0)
  conflicts  Int      @default(0)
  payload    Json?
  createdAt  DateTime @default(now())

  device OfflineDevice @relation(fields: [deviceId], references: [id])

  @@map("offline_sync_logs")
}

// ─── Communications ─────────────────────────────────────────────

enum CampaignChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  OPENED
  CLICKED
}

model Campaign {
  id          String          @id @default(cuid())
  eventId     String?
  userId      String
  name        String
  channel     CampaignChannel
  message     String         
  status      CampaignStatus  @default(DRAFT)
  guestTier   Int             @default(50)
  totalCost   Decimal         @default(0)
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  scheduledAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  event    Event?            @relation(fields: [eventId], references: [id])
  user     User              @relation(fields: [userId], references: [id])
  messages CampaignMessage[]
  payments Payment[]

  @@map("campaigns")
}

model CampaignMessage {
  id         String        @id @default(cuid())
  campaignId String
  recipient  String
  guestName  String?
  status     MessageStatus @default(PENDING)
  sentAt     DateTime?
  createdAt  DateTime      @default(now())

  campaign Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  logs     MessageLog[]

  @@map("campaign_messages")
}

model MessageLog {
  id        String   @id @default(cuid())
  messageId String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  message CampaignMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_logs")
}

// ─── VendorOS / Marketplace ───────────────────────────────────────

enum VendorProfileStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum VendorVerificationStatus {
  NOT_VERIFIED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  REVOKED
}

enum VendorLeadStatus {
  NEW
  VIEWED
  CONTACTED
  QUOTED
  ACCEPTED
  DECLINED
  EXPIRED
  BOOKED
}

enum VendorAvailabilityStatus {
  AVAILABLE
  PARTIAL
  FULLY_BOOKED
  UNAVAILABLE
  VACATION
}

model VendorCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments VendorCategoryAssignment[]

  @@map("vendor_categories")
}

model VendorPlan {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  priceGhs             Decimal  @default(0)
  currency             String   @default("GHS")
  durationDays         Int      @default(365)
  imageLimit           Int      @default(10)
  videoLimit           Int      @default(2)
  storageLimitMb       Int      @default(500)
  categoryLimit        Int      @default(2)
  portfolioEventLimit  Int      @default(5)
  verifiedBadge        Boolean  @default(false)
  featuredSearch       Boolean  @default(false)
  advancedAnalytics    Boolean  @default(false)
  priorityLeads        Boolean  @default(false)
  isActive             Boolean  @default(true)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vendors       Vendor[]
  subscriptions VendorSubscription[]

  @@map("vendor_plans")
}

model Vendor {
  id                    String                   @id @default(cuid())
  userId                String
  slug                  String?                  @unique
  businessName          String
  vendorType            String                   @default("individual")
  ownerName             String?
  email                 String?
  phone                 String?
  whatsapp              String?
  category              String
  description           String?
  bio                   String?
  location              String?
  address               String?
  city                  String?
  region                String?
  country               String                   @default("Ghana")
  serviceAreas          Json?
  yearsExperience       Int?
  profileImage          String?
  coverImage            String?
  rating                Decimal                  @default(0)
  reviewCount           Int                      @default(0)
  verificationStatus    VendorVerificationStatus @default(NOT_VERIFIED)
  planId                String?
  isVerified            Boolean                  @default(false)
  isFeatured            Boolean                  @default(false)
  isActive              Boolean                  @default(true)
  status                VendorProfileStatus      @default(ACTIVE)
  trustScore            Decimal                  @default(0)
  responseRate          Decimal                  @default(0)
  averageResponseTime   Int?
  completedEventsCount  Int                      @default(0)
  isClaimable           Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  user                  User                       @relation(fields: [userId], references: [id])
  plan                  VendorPlan?                @relation(fields: [planId], references: [id])
  services              VendorService[]
  bookings              VendorBooking[]
  reviews               VendorReview[]
  socialLinks           VendorSocialLink[]
  media                 VendorMedia[]
  rateCards             VendorRateCard[]
  eventReferences       VendorEventReference[]
  availability          VendorAvailability[]
  leads                 VendorLead[]
  verificationRequests  VendorVerificationRequest[]
  favorites             VendorFavorite[]
  claimRequests         VendorClaimRequest[]
  categoryAssignments   VendorCategoryAssignment[]
  analyticsEvents       VendorAnalyticsEvent[]
  subscriptions         VendorSubscription[]
  portfolioCases        EventPortfolioCase[]

  @@index([category])
  @@index([city])
  @@index([isFeatured])
  @@index([verificationStatus])
  @@map("vendors")
}

model VendorCategoryAssignment {
  id         String @id @default(cuid())
  vendorId   String
  categoryId String

  vendor   Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category VendorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId])
  @@map("vendor_category_assignments")
}

model VendorSocialLink {
  id        String   @id @default(cuid())
  vendorId  String
  platform  String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_social_links")
}

model VendorMedia {
  id               String   @id @default(cuid())
  vendorId         String
  type             String
  url              String
  thumbnailUrl     String?
  caption          String?
  eventReferenceId String?
  status           String   @default("active")
  sortOrder        Int      @default(0)
  sizeBytes        Int      @default(0)
  createdAt        DateTime @default(now())

  vendor         Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  eventReference VendorEventReference? @relation(fields: [eventReferenceId], references: [id])

  @@index([vendorId])
  @@map("vendor_media")
}

model VendorRateCard {
  id          String   @id @default(cuid())
  vendorId    String
  serviceName String
  priceMin    Decimal
  priceMax    Decimal?
  currency    String   @default("GHS")
  description String?
  packageType String?
  duration    String?
  notes       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_rate_cards")
}

model VendorEventReference {
  id              String   @id @default(cuid())
  vendorId        String
  eventTitle      String
  eventType       String?
  location        String?
  eventYear       Int?
  roleProvided    String?
  testimonial     String?
  celeventicEventId String?
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  vendor Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  media  VendorMedia[]

  @@map("vendor_event_references")
}

