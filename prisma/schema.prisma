  userId       String
  eventType    String
  eventTitle   String?
  budget       Decimal?
  currency     String          @default("GHS")
  guestCount   Int?
  location     String?
  venue        String?
  eventDate    DateTime?
  eventGoal    String?
  style        String?
  culturalPref String?
  isTicketed   Boolean         @default(false)
  isIndoor     Boolean?
  hostDetails  String?
  planSummary  String?
  aiProvider   String          @default("mock")
  status       EventPlanStatus @default(ACTIVE)
  version      Int             @default(1)
  rawPlan      Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  event          Event?               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id])
  budgetItems    EventBudgetItem[]
  timelineItems  EventTimelineItem[]
  checklistItems EventChecklistItem[]
  riskScores     EventRiskScore[]
  versions       EventPlanVersion[]

  @@index([eventId])
  @@index([userId])
  @@map("event_plans")
}

model EventPlanVersion {
  id           String   @id @default(cuid())
  eventPlanId  String
  version      Int
  planSnapshot Json
  createdAt    DateTime @default(now())

  plan EventPlan @relation(fields: [eventPlanId], references: [id], onDelete: Cascade)

  @@unique([eventPlanId, version])
