  @@map("event_checklists")
}

model EventRiskScore {
  id             String  @id @default(cuid())
  eventPlanId    String
  riskType       String
  score          Int     @default(50)
  severity       String
  recommendation String?

  plan EventPlan @relation(fields: [eventPlanId], references: [id], onDelete: Cascade)

  @@map("event_risk_scores")
}

model AiRequest {
  id        String   @id @default(cuid())
  userId    String
  module    String
  provider  String   @default("mock")
