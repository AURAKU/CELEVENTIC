// ─── Invitation MVP Product ─────────────────────────────────────

enum InvitationMvpStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  IN_PRODUCTION
  REVISION_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum InvitationWorkflowType {
  SELF_SERVICE
  AI_ASSISTED
  DESIGNER_ASSISTED
  BESPOKE
}

enum InvitationWorkflowStage {
  PACKAGE_SELECTED
  ADDONS_SELECTED
  PAYMENT_PENDING
  PAYMENT_SUCCESSFUL
  INFORMATION_PENDING
  PRODUCTION_STARTED
  DESIGN_READY
  CUSTOMER_REVIEWING
  REVISION_REQUESTED
  REVISION_IN_PROGRESS
  APPROVED
  DELIVERED
  PUBLISHED
  ARCHIVED
}

enum InvitationProductionStatus {
  NOT_STARTED
  ASSIGNED
  DESIGNING
  AWAITING_CUSTOMER_INFO
  AWAITING_APPROVAL
  REVISION
  APPROVED
  DELIVERED
}

enum RevisionType {
  MINOR
  MAJOR
}

enum RevisionChangeCategory {
  DATE_CHANGE
  TIME_CHANGE
  VENUE_CHANGE
  PHONE_CHANGE
  SPELLING
  THEME_CHANGE
  LAYOUT_CHANGE
  COLOR_OVERHAUL
  NEW_ANIMATION
  NEW_SECTION
  OTHER
}

enum RevisionPaymentStatus {
  PENDING
  PAID
  WAIVED
}

model InvitationCatalogTemplate {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  description         String?
  category            String
  style               String
  layoutSlug          String
  eventTypes          Json?
  packageSlugs        Json?
  previewGradient     String?
  previewImageUrl     String?
  previewVideoUrl     String?
  backgroundImageUrl  String?
  backgroundVideoUrl  String?
  motionReferenceUrl  String?
  inspirationMediaUrl String?
  priceGhs            Decimal?
  languages           Json?
  isPremium           Boolean  @default(false)
  isFeatured          Boolean  @default(false)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  orders InvitationOrder[]

  @@index([category])
  @@index([style])
  @@map("invitation_catalog_templates")
}

model InvitationProductPackage {
  id                        String   @id @default(cuid())
  name                      String
  slug                      String   @unique
  description               String?
  tagline                   String?
  bestFor                   String?
  priceGhs                  Decimal
  revisions                 Int      @default(1)
  deliveryDays              Int      @default(3)
  features                  Json?
  designerAssist            Boolean  @default(false)
  paymentRequiredToPublish  Boolean  @default(true)
  isPopular                 Boolean  @default(false)
  isBestValue               Boolean  @default(false)
  isActive                  Boolean  @default(true)
  sortOrder                 Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  orders  InvitationOrder[]
  prices  PackagePrice[]

  @@map("invitation_product_packages")
}

model InvitationAddon {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  description        String?
  category           String   @default("general")
  priceGhs           Decimal
  packageEligibility Json?
  deliveryImpactDays Int      @default(0)
  adminNotes         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("invitation_addons")
}

model InvitationOrder {
  id                 String                     @id @default(cuid())
  userId             String
  templateSlug       String
  packageSlug        String
  status             InvitationMvpStatus        @default(DRAFT)
  productionStatus   InvitationProductionStatus @default(NOT_STARTED)
  workflowType       InvitationWorkflowType     @default(SELF_SERVICE)
  workflowStage      InvitationWorkflowStage    @default(PACKAGE_SELECTED)
  previewUrl         String?
  previewVideoUrl    String?
  extraRevisionPriceGhs Decimal                 @default(79)
  eventType          String
  hostName           String?
  coupleName1        String?
  coupleName2        String?
  deceasedName       String?
  eventTitle         String?
  eventDate          DateTime?
  eventTime          String?
  venueName          String?
  landmark           String?
  mapsLink           String?
  dressCode          String?
  contactPhone       String?
  contactEmail       String?
  story              String?
  galleryUrls        Json?
  musicPreference    String?
  rsvpRequired       Boolean                    @default(true)
  guestCount         Int?
  addonSlugs         Json?
  designConfig       Json?
  sections           Json?
  invitationId       String?
  eventId            String?
  totalAmountGhs     Decimal                    @default(0)
  displayCurrency    String                     @default("GHS")
  displayAmount      Decimal?
  exchangeRate       Decimal?
  currency           String                     @default("GHS")
  shareUrl           String?
  languageMode         InvitationLanguageMode     @default(EN_FR)
  assignedDesignerId   String?
  adminNotes           String?
  revisionsUsed        Int                        @default(0)
  missingInfoRequest   String?
  archivedAt             DateTime?
  portfolioConsent       Boolean                    @default(false)
  termsAcceptedVersion   String?
  privacyAcceptedVersion String?
  aiGeneratedContent     Json?
  inspirationAssets      Json?
  fulfilledAddons        Json?
  idempotencyKey         String?                    @unique
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  user              User                        @relation(fields: [userId], references: [id])
  template          InvitationCatalogTemplate   @relation(fields: [templateSlug], references: [slug])
  package           InvitationProductPackage    @relation(fields: [packageSlug], references: [slug])
  assignedDesigner  User?                       @relation("OrderDesigner", fields: [assignedDesignerId], references: [id])
  payment           Payment?
  languageVersions  InvitationLanguageVersion[]
  blocks                InvitationBlock[]
  revisions             InvitationRevision[]
  productionAssignments ProductionAssignment[]
  approvals             InvitationApproval[]

  @@index([userId])
  @@index([status])
  @@index([workflowStage])
  @@index([assignedDesignerId])
  @@map("invitation_orders")
}

enum InvitationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model InvitationReview {
  id         String                 @id @default(cuid())
  author     String
  role       String?
  content    String
  rating     Int                    @default(5)
  status     InvitationReviewStatus @default(PENDING)
  isVerified Boolean                @default(false)
  isFeatured Boolean                @default(false)
  isActive   Boolean                @default(true)
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@map("invitation_reviews")
}

enum InvitationRevisionStatus {
  REQUESTED
  AWAITING_PAYMENT
  IN_PROGRESS
  AWAITING_APPROVAL
  COMPLETED
  CANCELLED
}

model InvitationRevision {
  id                String                   @id @default(cuid())
  invitationOrderId String
  revisionNumber    Int
  revisionType      RevisionType             @default(MINOR)
  changeCategory    RevisionChangeCategory   @default(OTHER)
  status            InvitationRevisionStatus @default(REQUESTED)
  notes             String?
  adminNotes        String?
  adminResponse     String?
  isExtraPaid       Boolean                  @default(false)
  amountGhs         Decimal?
  customerApproved  Boolean                  @default(false)
  customerApprovedAt DateTime?
  requestedAt       DateTime                 @default(now())
  completedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  invitationOrder InvitationOrder    @relation(fields: [invitationOrderId], references: [id], onDelete: Cascade)
  comments        RevisionComment[]
  payments        RevisionPayment[]
  approvals       InvitationApproval[]

  @@index([invitationOrderId])
  @@map("invitation_revisions")
}

model RevisionComment {
  id         String   @id @default(cuid())
  revisionId String
  userId     String
  isAdmin    Boolean  @default(false)
  content    String
  createdAt  DateTime @default(now())

  revision InvitationRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id])

  @@index([revisionId])
  @@map("revision_comments")
}

model RevisionPayment {
  id         String                @id @default(cuid())
  revisionId String
  paymentId  String?               @unique
  amountGhs  Decimal
  status     RevisionPaymentStatus @default(PENDING)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  revision InvitationRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  payment  Payment?           @relation(fields: [paymentId], references: [id])

  @@index([revisionId])
  @@map("revision_payments")
}

model ProductionAssignment {
  id          String    @id @default(cuid())
  orderId     String
  designerId  String
  assignedBy  String?
  notes       String?
  status      String    @default("ACTIVE")
  assignedAt  DateTime  @default(now())
  completedAt DateTime?

  order    InvitationOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  designer User            @relation("ProductionDesigner", fields: [designerId], references: [id])

  @@index([orderId])
  @@index([designerId])
  @@map("production_assignments")
}

model InvitationApproval {
  id         String   @id @default(cuid())
  orderId    String
  revisionId String?
  approvedBy String
  notes      String?
  approvedAt DateTime @default(now())

  order    InvitationOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revision InvitationRevision? @relation(fields: [revisionId], references: [id])

  @@index([orderId])
  @@map("invitation_approvals")
}

// ─── Invitation Commerce Engine ───────────────────────────────────

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  symbol    String
  name      String
  enabled   Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("currencies")
}

model ExchangeRate {
  id             String   @id @default(cuid())
  baseCurrency   String   @default("GHS")
  targetCurrency String
  rate           Decimal
  source         String   @default("manual")
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency])
  @@map("exchange_rates")
}

model PackagePrice {
  id        String   @id @default(cuid())
  packageId String
  amountGhs Decimal
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package InvitationProductPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, isActive])
  @@map("package_prices")
}

model PaymentCurrencyLog {
  id                String   @id @default(cuid())
  paymentId         String
  invitationOrderId String?
  baseCurrency      String   @default("GHS")
  baseAmount        Decimal
  displayCurrency   String
  displayAmount     Decimal
  exchangeRate      Decimal
  rateSource        String   @default("manual")
  createdAt         DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_currency_logs")
}

// ─── Internationalization (i18n) ──────────────────────────────────

enum InvitationLanguageMode {
  EN_ONLY
  FR_ONLY
  EN_FR
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  enabled   Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("languages")
}

model Translation {
  id              String   @id @default(cuid())
  key             String
  namespace       String   @default("common")
  enValue         String
  frValue         String?
  editableByAdmin Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([namespace, key])
  @@index([namespace])
  @@map("translations")
}

model UserLanguagePreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  languageCode String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_language_preferences")
}

model InvitationLanguageVersion {
  id                String                 @id @default(cuid())
  invitationOrderId String?
  invitationId      String?
  languageCode      String
  mode              InvitationLanguageMode @default(EN_FR)
  eventTitle        String?
  story             String?
  dressCode         String?
  venueName         String?
  landmark          String?
  hostName          String?
  customLabels      Json?
  isPublished       Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  invitationOrder InvitationOrder? @relation(fields: [invitationOrderId], references: [id], onDelete: Cascade)

  @@unique([invitationOrderId, languageCode])
  @@index([invitationId])
  @@map("invitation_language_versions")
}

// ─── Dynamic Invitation Block Builder ─────────────────────────────

model InvitationBlockTemplate {
  id                  String   @id @default(cuid())
  blockType           String
  category            String   @default("default")
  eventTypes          Json?
  titleEn             String
  titleFr             String?
  subtitleEn          String?
  subtitleFr          String?
  defaultContentJson  Json?
  defaultStyleVariant String   @default("elegant")
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([blockType, category])
  @@index([category])
  @@map("invitation_block_templates")
}

model InvitationBlock {
  id                String   @id @default(cuid())
  invitationId      String?
  invitationOrderId String?
  blockType         String
  title             String?
  subtitle          String?
  contentJson       Json?
  sortOrder         Int      @default(0)
  isVisible         Boolean  @default(true)
  styleVariant      String   @default("elegant")
  language          String   @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invitation      Invitation?      @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitationOrder InvitationOrder? @relation(fields: [invitationOrderId], references: [id], onDelete: Cascade)
  contents        InvitationBlockContent[]
  media           InvitationMedia[]
  galleryItems    InvitationGalleryItem[]

  @@index([invitationId, sortOrder])
  @@index([invitationOrderId, sortOrder])
  @@map("invitation_blocks")
}

model InvitationBlockContent {
  id          String   @id @default(cuid())
  blockId     String
  language    String   @default("en")
  title       String?
  subtitle    String?
  content     String?
  contentJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  block InvitationBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, language])
  @@map("invitation_block_content")
}

model InvitationMedia {
  id                String   @id @default(cuid())
  blockId           String?
  invitationId      String?
  invitationOrderId String?
  url               String
  type              String   @default("image")
  alt               String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  block InvitationBlock? @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@map("invitation_media")
}

model InvitationGalleryItem {
  id        String   @id @default(cuid())
  blockId   String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  block InvitationBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, sortOrder])
  @@map("invitation_gallery_items")
}

// ─── Legal & Compliance ───────────────────────────────────────────

enum ConsentType {
