  version              String
  titleEn              String
  titleFr              String
  descriptionEn        String   @default("")
  descriptionFr        String   @default("")
  contentEn            String
  contentFr            String
  effectiveDate        DateTime @default(now())
  requiresReacceptance Boolean  @default(false)
  isPublished          Boolean  @default(true)
  createdBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([slug, version])
  @@index([slug, isPublished])
  @@map("legal_document_versions")
}

model UserConsentRecord {
  id        String      @id @default(cuid())
  userId    String
  type      ConsentType
  version   String?
  value     String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("user_consent_records")
}

// ─── InvitationOS Analytics ───────────────────────────────────────

model InvitationAnalyticsEvent {
  id             String   @id @default(cuid())
  eventType      String
  orderId        String?
  invitationId   String?
  guestId        String?
  userId         String?
  templateSlug   String?
  packageSlug    String?
