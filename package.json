{
    "name": "celeventic",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "dev:3000": "next dev -p 3000",
        "dev:turbo": "next dev --turbopack",
        "build": "next build",
        "build:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build",
        "start": "next start",
        "start:3000": "next start -p 3000",
        "lint": "next lint",
        "lint:tokens": "node scripts/check-token-purity.mjs",
        "lint:uniqueness": "tsx scripts/check-template-uniqueness.ts",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "tsx prisma/seed.ts",
        "db:seed-wave1": "tsx scripts/seed-wave1-catalog.ts",
        "db:seed-music": "tsx scripts/seed-music-library.ts",
        "music:sync": "tsx scripts/sync-music-assets.ts",
        "db:ensure-admin": "tsx scripts/ensure-admin.ts",
        "seed:admin": "tsx scripts/seed-admin.ts",
        "db:deploy": "prisma db push && tsx scripts/seed-admin.ts",
        "jobs:worker": "tsx scripts/video-jobs-worker.ts",
        "video:worker": "tsx scripts/video-jobs-worker.ts",
        "video:backfill": "tsx scripts/backfill-video-playback.ts",
        "video:backfill:dry-run": "tsx scripts/backfill-video-playback.ts --dry-run",
        "smoke-test": "node scripts/smoke-test-local.mjs",
        "smoke-test:pages": "node scripts/smoke-test-local.mjs && node scripts/smoke-test-authed-pages.mjs",
        "test:auth": "tsx --test src/lib/auth/__tests__/*.test.ts",
        "test:video": "tsx --test src/lib/video/__tests__/*.test.ts",
        "test:uploads": "tsx --test src/app/api/uploads/__tests__/*.test.ts",
        "test:experience-engine": "tsx --test src/lib/experience-engine/__tests__/*.test.ts",
        "db:studio": "prisma studio",
        "brand:assets": "node scripts/setup-brand-assets.mjs",
        "prepare:local": "node scripts/setup-brand-assets.mjs && npm run db:push",
        "postinstall": "prisma generate",
        "predev": "node scripts/setup-brand-assets.mjs"
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.9.1",
        "@aws-sdk/client-mediaconvert": "^3.1094.0",
        "@aws-sdk/client-s3": "^3.1091.0",
        "@aws-sdk/s3-request-presigner": "^3.1094.0",
        "@hookform/resolvers": "^5.0.1",
        "@prisma/client": "^6.9.0",
        "@radix-ui/react-avatar": "^1.1.10",
        "@radix-ui/react-checkbox": "^1.3.2",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-dropdown-menu": "^2.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-select": "^2.2.5",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.5",
        "@radix-ui/react-tabs": "^1.1.12",
        "@radix-ui/react-toast": "^1.2.14",
        "@react-three/drei": "^10.0.7",
        "@react-three/fiber": "^9.1.2",
        "bcryptjs": "^3.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^12.16.0",
        "hls.js": "^1.6.16",
        "html5-qrcode": "^2.3.8",
        "ioredis": "^5.6.1",
        "lucide-react": "^0.513.0",
        "next": "^15.3.3",
        "next-auth": "^4.24.11",
        "otplib": "^12.0.1",
        "qrcode": "^1.5.4",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.57.0",
        "sharp": "^0.33.5",
        "tailwind-merge": "^3.3.0",
        "three": "^0.176.0",
        "uuid": "^11.1.0",
        "zod": "^3.25.51"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@tailwindcss/postcss": "^4.1.8",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.15.29",
        "@types/qrcode": "^1.5.5",
        "@types/react": "^19.1.6",
        "@types/react-dom": "^19.1.5",
        "@types/three": "^0.176.0",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.28.0",
        "eslint-config-next": "^15.3.3",
        "prisma": "^6.9.0",
        "tailwindcss": "^4.1.8",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}
